@startuml diagramme_classes_uml
' =============================================================================
' Diagramme de classes UML metier -- GLPI CY Tech
' Vue OO du modele : abstraction "Materiel" + paquets fonctionnels
' =============================================================================

!theme plain
skinparam backgroundColor #FAFBFC
skinparam shadowing false
skinparam linetype polyline
skinparam roundcorner 8
skinparam padding 4
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 11
skinparam ArrowColor #5D6D7E
skinparam ArrowThickness 1

skinparam class {
  BorderThickness 1
  FontStyle bold
  AttributeFontStyle plain
  AttributeFontSize 10
}

skinparam package {
  BackgroundColor #FFFFFF
  BorderColor #BFC9CA
  FontColor #34495E
  FontSize 13
  FontStyle bold
}

' Palette par concept

title <size:18>**Diagramme de classes UML — GLPI CY Tech**</size>

' =============================================================================
package "Organisation" {
  class Site <<orga>> #FDEBD0 {
    -id
    -nom : String
    -ville : String
    +getInventaire()
  }

  class HierarchyLevel <<orga>> #FDEBD0 {
    -id
    -nom : String
    -niveau : int
    +getEnfants()
    +getCheminComplet()
  }

  class Localisation <<orga>> #FDEBD0 {
    -id
    -nom, batiment, salle, etage
  }

  Site "1" *-down- "*" HierarchyLevel
  HierarchyLevel "0..1" --> "*" HierarchyLevel : parent
  HierarchyLevel "1" *-down- "*" Localisation
  Localisation "0..1" --> "*" Localisation : parent
}

' =============================================================================
package "Referentiels" {
  class Fabricant <<ref>> #E8F4FD {
    -id
    -nom : String
  }

  class Etat <<ref>> #E8F4FD {
    -id
    -nom : String
  }

  class TypeOrdinateur <<ref>> #E8F4FD {
    -id
    -machine_type
  }

  class ModeleOrdinateur <<ref>> #E8F4FD {
    -id
    -nom, ref_produit
  }

  Fabricant "1" --> "*" ModeleOrdinateur
}

' =============================================================================
package "Utilisateurs et acces" {
  class Profil <<user>> #FAD7A0 {
    -id
    -nom : String
    -interface : String
    --
    <i>Admin, Technicien,
    Enseignant, Etudiant,
    Administration</i>
  }

  class Utilisateur <<user>> #FAD7A0 {
    -id
    -login : String
    -nom, prenom, email
    -est_actif, est_supprime
    +affecter(m : Materiel)
    +archiver()
  }

  class Groupe <<user>> #FAD7A0 {
    -id
    -nom : String
  }

  Profil "1" --> "*" Utilisateur
  Groupe "0..1" --> "*" Groupe : parent
}

' =============================================================================
package "Materiel (hierarchie)" {
  abstract class Materiel <<abs>> #FFFFFF {
    #id
    #nom : String
    #numero_serie
    #est_supprime : boolean
    +affecter(u : Utilisateur)
    +liberer()
    +changerEtat(e : Etat)
  }

  class Ordinateur <<mat>> #D5F5E3 {
    -numero_inventaire
    -date_achat : Date
    +installerLogiciel(v)
  }

  class Peripherique <<mat>> #D5F5E3 {
    -type : String
  }

  class Telephone <<mat>> #D5F5E3 {
    -numero_tel
    -service
  }

  Materiel <|-- Ordinateur
  Materiel <|-- Peripherique
  Materiel <|-- Telephone
}

' =============================================================================
package "Logiciels" {
  class Logiciel <<logi>> #FCF3CF {
    -id
    -nom, editeur
  }

  class VersionLogiciel <<logi>> #FCF3CF {
    -id
    -nom : String
  }

  class Installation <<logi>> #FCF3CF {
    -id
    -date_installation
  }

  Logiciel "1" --> "*" VersionLogiciel
  VersionLogiciel "1" --> "*" Installation
}

' =============================================================================
package "Reseau" {
  class TypeEquipReseau <<net>> #FADBD8 {
    -id
    -nom : String
    --
    <i>Switch, Routeur WiFi,
    Borne WiFi</i>
  }

  class EquipementReseau <<net>> #FADBD8 {
    -id
    -nom, numero_serie
    -nb_ports
    +getTauxOccupation()
  }

  class PortReseau <<net>> #FADBD8 {
    -id
    -adresse_mac
    -type_port
    -vitesse
    -est_actif
  }

  TypeEquipReseau "0..1" --> "*" EquipementReseau
  EquipementReseau "1" *-- "*" PortReseau
}

' =============================================================================
package "Audit" {
  class Historique <<audit>> #E8DAEF {
    -id
    -type_objet
    -objet_id
    -type_action
    -date_action
    --
    <i>INSERT / UPDATE / DELETE</i>
  }
}

' =============================================================================
package "Optimisation (cluster)" {
  class OrdinateurCl <<cluster>> #F5CBA7 {
    <i>Memes attributs que Ordinateur</i>
    --
    Co-localise sur disque
    via cluster Oracle
  }

  class PeripheriqueCl <<cluster>> #F5CBA7 {
    <i>Memes attributs que Peripherique</i>
  }
}

' =============================================================================
' Relations transversales (entre paquets)
' =============================================================================
Site "1" --> "*" Utilisateur
HierarchyLevel "1" --> "*" Utilisateur
HierarchyLevel "1" --> "*" Materiel
Site "1" --> "*" Materiel
Localisation "0..1" --> "*" Materiel
Fabricant "1" --> "*" Materiel
Etat "1" --> "*" Materiel
Utilisateur "0..1" --> "*" Materiel : possede

Ordinateur "1" --> "*" Installation
Fabricant "1" --> "*" Logiciel

Site "1" --> "*" EquipementReseau
HierarchyLevel "1" --> "*" EquipementReseau
Localisation "0..1" --> "*" EquipementReseau
Fabricant "1" --> "*" EquipementReseau

Utilisateur "0..1" --> "*" Historique

Ordinateur   ..> OrdinateurCl   : <i>sync</i>
Peripherique ..> PeripheriqueCl : <i>sync</i>

@enduml
