@startuml schema_relationnel
' =============================================================================
' Schema relationnel (MLD) -- GLPI CY Tech multi-sites
' Version visuellement aeree : groupes par domaine, FK explicites,
' attributs simplifies (PK / FK / colonnes-cles uniquement).
' =============================================================================

!theme plain
skinparam backgroundColor #FAFBFC
skinparam shadowing false
skinparam linetype polyline
skinparam roundcorner 6
skinparam padding 4
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 11
skinparam ArrowColor #5D6D7E
skinparam ArrowFontColor #5D6D7E

skinparam class {
  BorderThickness 1
  FontStyle bold
  AttributeFontStyle plain
  AttributeFontSize 10
}

' Palette par domaine

title <size:18>**Schema relationnel — GLPI CY Tech (Oracle multi-sites)**</size>\n<size:11><i>PK en gras • FK en italique • Couleur = domaine fonctionnel</i></size>

' =============================================================================
' BLOC ORGANISATION
' =============================================================================
together {
  class sites <<orga>> #FDEBD0 {
    **+ id**
    nom
    ville, adresse
    code_postal, telephone
  }

  class hierarchy_level <<orga>> #FDEBD0 {
    **+ id**
    nom
    //#parent_id//
    //#site_id//
    niveau, nom_complet
  }

  class localisations <<orga>> #FDEBD0 {
    **+ id**
    nom, batiment
    salle, etage
    //#hierarchy_level_id//
    //#localisation_parent_id//
  }
}

' =============================================================================
' BLOC REFERENTIELS
' =============================================================================
together {
  class fabricants <<ref>> #E8F4FD {
    **+ id**
    nom (UNIQUE)
  }

  class etats <<ref>> #E8F4FD {
    **+ id**
    nom (UNIQUE)
    etat
  }

  class types_ordinateur <<ref>> #E8F4FD {
    **+ id**
    machine_type
  }

  class modeles_ordinateur <<ref>> #E8F4FD {
    **+ id**
    nom, ref_produit
    //#fabricant_id//
  }

  class profils <<ref>> #E8F4FD {
    **+ id**
    nom (UNIQUE)
    interface
  }
}

' =============================================================================
' BLOC UTILISATEURS
' =============================================================================
together {
  class utilisateurs <<users>> #FAD7A0 {
    **+ id**
    login (UNIQUE)
    nom, prenom
    email, mot_de_passe
    //#hierarchy_level_id//
    //#profil_id//
    //#site_id//
    est_actif, est_supprime
  }

  class groupes <<users>> #FAD7A0 {
    **+ id**
    nom
    //#hierarchy_level_id//
    //#groupe_parent_id//
  }
}

' =============================================================================
' BLOC MATERIEL
' =============================================================================
together {
  class ordinateurs <<mat>> #D5F5E3 {
    **+ id**
    nom, numero_serie
    //#hierarchy_level_id//
    //#localisation_id//
    //#type_ordinateur_id//
    //#modele_id//
    //#fabricant_id//
    //#etat_id//
    //#utilisateur_id//
    //#site_id//
    date_achat
    est_supprime
  }

  class peripheriques <<mat>> #D5F5E3 {
    **+ id**
    nom, numero_serie
    type_peripherique
    //#hierarchy_level_id//
    //#localisation_id//
    //#fabricant_id//, //#etat_id//
    //#utilisateur_id//, //#site_id//
  }

  class telephones <<mat>> #D5F5E3 {
    **+ id**
    nom, numero_tel
    type_telephone
    service
    //#hierarchy_level_id//
    //#localisation_id//
    //#fabricant_id//, //#etat_id//
    //#utilisateur_id//, //#site_id//
  }
}

' =============================================================================
' BLOC LOGICIELS
' =============================================================================
together {
  class logiciels <<logi>> #FCF3CF {
    **+ id**
    nom, editeur
    //#fabricant_id//
  }

  class versions_logiciel <<logi>> #FCF3CF {
    **+ id**
    nom
    //#logiciel_id//
    //#etat_id//
  }

  class installations_logiciels <<logi>> #FCF3CF {
    **+ id**
    //#ordinateur_id//
    //#version_logiciel_id//
    date_installation
    --
    UNIQUE(ordi, version)
  }
}

' =============================================================================
' BLOC RESEAU
' =============================================================================
together {
  class types_equip_reseau <<net>> #FADBD8 {
    **+ id**
    nom (UNIQUE)
  }

  class equipements_reseau <<net>> #FADBD8 {
    **+ id**
    nom, numero_serie
    nb_ports
    //#hierarchy_level_id//
    //#localisation_id//
    //#type_equip_id//
    //#fabricant_id//, //#etat_id//
    //#site_id//
  }

  class ports_reseau <<net>> #FADBD8 {
    **+ id**
    nom, adresse_mac
    type_port, vitesse
    est_actif
    //#equipement_id//
  }
}

' =============================================================================
' BLOC CLUSTER (optimisation)
' =============================================================================
together {
  class ordinateurs_cl <<cluster>> #F5CBA7 {
    **+ id**
    //memes colonnes que ordinateurs//
    --
    **CLUSTER cl_materiel_localisation**
    cle = localisation_id
  }

  class peripheriques_cl <<cluster>> #F5CBA7 {
    **+ id**
    //memes colonnes que peripheriques//
    --
    **CLUSTER cl_materiel_localisation**
    cle = localisation_id
  }
}

' =============================================================================
' BLOC AUDIT
' =============================================================================
class historique <<audit>> #E8DAEF {
  **+ id**
  type_objet
  objet_id
  champ_modifie
  ancienne_valeur
  nouvelle_valeur
  type_action
  //#utilisateur_id//
  date_action
}

' =============================================================================
' RELATIONS (groupees par theme pour lisibilite)
' =============================================================================

' --- Hierarchies auto-referentes ---
hierarchy_level "*" --> "0..1" hierarchy_level : parent
localisations  "*" --> "0..1" localisations  : parent
groupes        "*" --> "0..1" groupes        : parent

' --- Sites ---
sites "1" <-- "*" hierarchy_level
sites "1" <-- "*" utilisateurs
sites "1" <-- "*" ordinateurs
sites "1" <-- "*" peripheriques
sites "1" <-- "*" telephones
sites "1" <-- "*" equipements_reseau

' --- Organisation interne ---
hierarchy_level "1" <-- "*" localisations
hierarchy_level "1" <-- "*" utilisateurs
hierarchy_level "1" <-- "*" groupes

' --- Profils ---
profils "1" <-- "*" utilisateurs

' --- Materiel : referentiels ---
fabricants         "1" <-- "*" modeles_ordinateur
modeles_ordinateur "1" <-- "*" ordinateurs
types_ordinateur   "1" <-- "*" ordinateurs

' --- Materiel : sites / locs / utilisateurs ---
hierarchy_level "1" <-- "*" ordinateurs
hierarchy_level "1" <-- "*" peripheriques
hierarchy_level "1" <-- "*" telephones
hierarchy_level "1" <-- "*" equipements_reseau
localisations "0..1" <-- "*" ordinateurs
localisations "0..1" <-- "*" peripheriques
localisations "0..1" <-- "*" telephones
localisations "0..1" <-- "*" equipements_reseau
utilisateurs "0..1" <-- "*" ordinateurs
utilisateurs "0..1" <-- "*" peripheriques
utilisateurs "0..1" <-- "*" telephones

' --- Logiciels ---
logiciels         "1" <-- "*" versions_logiciel
versions_logiciel "1" <-- "*" installations_logiciels
ordinateurs       "1" <-- "*" installations_logiciels

' --- Reseau ---
types_equip_reseau "0..1" <-- "*" equipements_reseau
equipements_reseau "1"   <-- "*" ports_reseau

' --- Audit ---
utilisateurs "0..1" <-- "*" historique

' --- Cluster ---
ordinateurs   ..> ordinateurs_cl   : <i>sync (perf)</i>
peripheriques ..> peripheriques_cl : <i>sync (perf)</i>

' =============================================================================
' LEGENDE
' =============================================================================
legend right
|<#E8F4FD>     | Referentiels |
|<#FDEBD0>     | Organisation (sites, hierarchie, locs) |
|<#FAD7A0>     | Utilisateurs et groupes |
|<#D5F5E3>     | Materiel (ordi / periph / tel) |
|<#FCF3CF>     | Logiciels |
|<#FADBD8>     | Reseau |
|<#F5CBA7>     | Tables clustered (optimisation) |
|<#E8DAEF>     | Audit (polymorphique) |
endlegend

@enduml
