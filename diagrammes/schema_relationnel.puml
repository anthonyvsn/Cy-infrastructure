@startuml schema_relationnel
' =============================================================================
' Schema relationnel (MLD) -- Projet GLPI CY Tech multi-sites
' Auteur : equipe GLPI CY Tech
' Date   : 2026-05-13
' =============================================================================
' Convention :
'   * <attribut>     = cle primaire (PK)
'   # <attribut>     = cle etrangere (FK)
'   + <attribut>     = colonne UNIQUE
'   - <attribut>     = colonne ordinaire
' =============================================================================

!define PK(x) <b><color:#B03A2E>x</color></b>
!define FK(x) <color:#21618C>x</color>

skinparam shadowing false
skinparam linetype ortho
skinparam class {
  BackgroundColor #FDFEFE
  BorderColor     #2E4053
  ArrowColor      #5D6D7E
  FontName        "Courier New"
  FontSize        11
}
skinparam package {
  BackgroundColor #F7F9F9
  BorderColor     #ABB2B9
}

title MLD -- BDD GLPI CY Tech (Oracle 19c)

' =====================================================================
package "TS_USERS : referentiels partages" as PUSERS {

  entity "sites" as sites {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(100) NOT NULL
    adresse : VARCHAR2(255)
    ville : VARCHAR2(100) NOT NULL
    code_postal : VARCHAR2(10)
    telephone : VARCHAR2(20)
    date_creation : DATE
    date_modification : DATE
  }

  entity "entites" as entites {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    FK(entite_parent_id) : NUMBER -> entites(id)
    FK(site_id) : NUMBER NOT NULL -> sites(id)
    niveau : NUMBER DEFAULT 0
    nom_complet : VARCHAR2(500)
    est_recursif : NUMBER(1)
    date_creation : DATE
    date_modification : DATE
  }

  entity "localisations" as locs {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    nom_complet : VARCHAR2(500)
    FK(entite_id) : NUMBER NOT NULL -> entites(id)
    FK(localisation_parent_id) : NUMBER -> localisations(id)
    batiment : VARCHAR2(50)
    salle : VARCHAR2(20)
    etage : VARCHAR2(20)
  }

  entity "fabricants" as fab {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) UNIQUE NOT NULL
  }

  entity "etats" as etats {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) UNIQUE NOT NULL
    etat : VARCHAR2(50)
  }

  entity "types_ordinateur" as tordi {
    * PK(id) : NUMBER
    --
    machine_type : VARCHAR2(255) NOT NULL
  }

  entity "modeles_ordinateur" as mordi {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    ref_produit : VARCHAR2(255)
    FK(fabricant_id) : NUMBER -> fabricants(id)
  }
}

' =====================================================================
package "TS_USERS : utilisateurs et profils" as PUSERS2 {

  entity "profils" as profils {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) UNIQUE NOT NULL
    interface : VARCHAR2(50) CHECK in (central,helpdesk)
    date_creation : DATE
  }

  entity "utilisateurs" as users {
    * PK(id) : NUMBER
    --
    + login : VARCHAR2(255) UNIQUE NOT NULL
    mot_de_passe : VARCHAR2(255) NOT NULL
    nom : VARCHAR2(255)
    prenom : VARCHAR2(255)
    email : VARCHAR2(255)
    telephone : VARCHAR2(50)
    FK(entite_id) : NUMBER -> entites(id)
    FK(localisation_id) : NUMBER -> localisations(id)
    FK(profil_id) : NUMBER -> profils(id)
    FK(site_id) : NUMBER -> sites(id)
    langue : VARCHAR2(10) DEFAULT 'fr_FR'
    est_actif : NUMBER(1) CHECK in (0,1)
    est_supprime : NUMBER(1) CHECK in (0,1)
    type_auth : NUMBER DEFAULT 1
    date_debut : DATE
    date_fin : DATE
  }

  entity "profils_utilisateurs" as pu {
    * PK(id) : NUMBER
    --
    FK(utilisateur_id) : NUMBER NOT NULL -> utilisateurs(id)
    FK(profil_id) : NUMBER NOT NULL -> profils(id)
    FK(entite_id) : NUMBER NOT NULL -> entites(id)
    est_recursif : NUMBER(1)
    est_dynamique : NUMBER(1)
    UNIQUE(utilisateur_id, profil_id, entite_id)
  }

  entity "groupes" as groupes {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    FK(entite_id) : NUMBER NOT NULL -> entites(id)
    FK(groupe_parent_id) : NUMBER -> groupes(id)
    est_recursif : NUMBER(1)
    commentaire : VARCHAR2(255)
  }
}

' =====================================================================
package "TS_MATERIEL_CERGY" as PMAT {

  entity "ordinateurs" as ordi {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    numero_serie : VARCHAR2(255)
    numero_inventaire : VARCHAR2(255)
    FK(entite_id) : NUMBER NOT NULL
    FK(localisation_id) : NUMBER
    FK(type_ordinateur_id) : NUMBER
    FK(modele_id) : NUMBER
    FK(fabricant_id) : NUMBER
    FK(etat_id) : NUMBER
    FK(utilisateur_id) : NUMBER
    FK(groupe_id) : NUMBER
    FK(technicien_id) : NUMBER
    FK(site_id) : NUMBER NOT NULL
    commentaire : VARCHAR2(255)
    est_supprime : NUMBER(1)
    est_template : NUMBER(1)
    date_achat : DATE
  }

  entity "peripheriques" as periph {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    numero_serie : VARCHAR2(255)
    type_peripherique : VARCHAR2(100) CHECK (imprimante,souris,clavier,...)
    FK(entite_id) : NUMBER NOT NULL
    FK(localisation_id) : NUMBER
    FK(fabricant_id) : NUMBER
    FK(etat_id) : NUMBER
    FK(utilisateur_id) : NUMBER
    FK(site_id) : NUMBER NOT NULL
    est_supprime : NUMBER(1)
  }

  entity "telephones" as tel {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    numero_serie : VARCHAR2(255)
    numero_tel : VARCHAR2(50)
    type_telephone : VARCHAR2(50) CHECK in (fixe,mobile,ip)
    FK(entite_id) : NUMBER NOT NULL
    FK(localisation_id) : NUMBER
    FK(fabricant_id) : NUMBER
    FK(etat_id) : NUMBER
    FK(utilisateur_id) : NUMBER
    FK(site_id) : NUMBER NOT NULL
    service : VARCHAR2(100)
  }

  entity "logiciels" as log {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    editeur : VARCHAR2(255)
    FK(fabricant_id) : NUMBER
    FK(entite_id) : NUMBER
    est_supprime : NUMBER(1)
  }

  entity "versions_logiciel" as vlog {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    FK(logiciel_id) : NUMBER NOT NULL
    FK(etat_id) : NUMBER
  }

  entity "installations_logiciels" as ilog {
    * PK(id) : NUMBER
    --
    FK(ordinateur_id) : NUMBER NOT NULL
    FK(version_logiciel_id) : NUMBER NOT NULL
    date_installation : DATE
    UNIQUE(ordinateur_id, version_logiciel_id)
  }
}

' =====================================================================
package "TS_NETWORK_CERGY" as PNET {

  entity "types_equip_reseau" as ttreseau {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) UNIQUE NOT NULL
  }

  entity "equipements_reseau" as eqreseau {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255) NOT NULL
    numero_serie : VARCHAR2(255)
    FK(entite_id) : NUMBER NOT NULL
    FK(localisation_id) : NUMBER
    FK(type_equip_id) : NUMBER
    FK(fabricant_id) : NUMBER
    FK(etat_id) : NUMBER
    FK(site_id) : NUMBER NOT NULL
    nb_ports : NUMBER
  }

  entity "ports_reseau" as port {
    * PK(id) : NUMBER
    --
    nom : VARCHAR2(255)
    FK(equipement_id) : NUMBER NOT NULL
    adresse_mac : VARCHAR2(50)
    type_port : VARCHAR2(20) CHECK in (ethernet,wifi)
    vitesse : NUMBER
    est_actif : NUMBER(1)
  }
}

' =====================================================================
package "TS_USERS : audit" as PAUDIT {

  entity "historique" as hist {
    * PK(id) : NUMBER
    --
    type_objet : VARCHAR2(100) NOT NULL
    objet_id : NUMBER NOT NULL
    FK(utilisateur_id) : NUMBER -> utilisateurs(id)
    champ_modifie : VARCHAR2(255)
    ancienne_valeur : VARCHAR2(4000)
    nouvelle_valeur : VARCHAR2(4000)
    type_action : VARCHAR2(20) CHECK (INSERT,UPDATE,DELETE)
    date_action : DATE
  }
}

' ===================== RELATIONS / CARDINALITES =====================

' Hierarchies (auto-references)
entites      ||--o{ entites      : "parent"
locs         ||--o{ locs         : "parent"
groupes      ||--o{ groupes      : "parent"

' Referentiel <-> entites/localisations
sites        ||--|{ entites      : "site"
entites      ||--o{ locs         : "rattache"
fab          ||--o{ mordi        : "produit"

' Utilisateurs
users        }o--|| sites
users        }o--|| entites
users        }o--o| locs
users        }o--o| profils
users        ||--o{ pu
profils      ||--o{ pu
entites      ||--o{ pu
groupes      }o--|| entites

' Materiel
sites        ||--o{ ordi
sites        ||--o{ periph
sites        ||--o{ tel
entites      ||--o{ ordi
entites      ||--o{ periph
entites      ||--o{ tel
locs         ||--o{ ordi
locs         ||--o{ periph
fab          ||--o{ ordi
fab          ||--o{ periph
fab          ||--o{ tel
etats        ||--o{ ordi
etats        ||--o{ periph
etats        ||--o{ tel
tordi        ||--o{ ordi
mordi        ||--o{ ordi
users        ||--o{ ordi         : "affecte"
users        ||--o{ periph
users        ||--o{ tel

' Logiciels
log          ||--o{ vlog
vlog         ||--o{ ilog
ordi         ||--o{ ilog

' Reseau
ttreseau     ||--o{ eqreseau
sites        ||--o{ eqreseau
entites      ||--o{ eqreseau
locs         ||--o{ eqreseau
fab          ||--o{ eqreseau
etats        ||--o{ eqreseau
eqreseau     ||--|{ port

' Audit (polymorphe par chaine -- pas de FK forte)
hist         }o..o| users        : "auteur"

note bottom of hist
  Polymorphisme par chaine :
  (type_objet, objet_id) referencent
  une ligne d'une table sensible
  (ordinateurs, utilisateurs, ...).
  Index compose idx_hist_objet
  pour les recherches frequentes.
end note

note right of PUSERS
  TS_USERS contient toutes les donnees
  partagees inter-sites (referentiels,
  utilisateurs, audit).
end note

note right of PMAT
  TS_MATERIEL_CERGY heberge le parc
  Cergy. Une instance miroir
  TS_MATERIEL_PAU heberge celui de Pau
  (BDDR + DB link db_pau).
end note

@enduml
