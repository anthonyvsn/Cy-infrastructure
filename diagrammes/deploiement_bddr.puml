@startuml deploiement_bddr
' =============================================================================
' Diagramme de deploiement BDDR -- GLPI CY Tech
' 2 sites (Cergy + Pau), 2 PDB Oracle 21c XE relies par DB links
' =============================================================================

!theme plain
skinparam backgroundColor #FAFBFC
skinparam shadowing false
skinparam linetype polyline
skinparam roundcorner 8
skinparam padding 4
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam ArrowColor #5D6D7E

skinparam node {
  BackgroundColor #FFFFFF
  BorderColor #34495E
  BorderThickness 2
}

skinparam database {
  BackgroundColor #D6EAF8
  BorderColor #2874A6
  FontColor #1A5276
  FontStyle bold
}

skinparam component {
  BackgroundColor #FCF3CF
  BorderColor #B7950B
}

skinparam folder {
  BackgroundColor #D5F5E3
  BorderColor #1E8449
}

skinparam actor {
  BackgroundColor #FAD7A0
  BorderColor #B9770E
}

title <size:18>**Architecture BDDR — GLPI CY Tech**</size>\n<size:11><i>2 instances Oracle XE 21c reparties sur Cergy et Pau</i></size>

' =============================================================================
' CERGY (gauche)
' =============================================================================
node "**CY Tech — Cergy**\n<size:10><i>Site du Parc + Fermat</i></size>" as N_CERGY #E8F4FD {

  database "**Oracle XE 21c**\n<size:10>CDB cergy</size>" as DB_C {

    folder "PDB **XE_CERGY**" as PDB_C #FFFFFF {

      component "**Schema ADMIN_CYTECH**\n<size:10>(donnees + logique)</size>" as S_C {
        [Referentiels\n(sites, hierarchy_level,\nlocs, fabricants, etats)]
        [Utilisateurs + Groupes]
        [Materiel Cergy\n(ordis, periph, tel,\nlogiciels)]
        [Reseau Cergy\n(equipements + ports)]
        [**Cluster**\ncl_materiel_localisation\n+ tables _cl]
        [Historique (audit)]
      }

      component "**Triggers + Packages**" as PL_C {
        [42 triggers\n(audit, validation,\nINSTEAD OF)]
        [PKG_PARC_INFO\nPKG_STATS\nPKG_RESEAU\nPKG_MAINTENANCE]
      }

      component "**Vues**" as V_C {
        [vue_parc_cergy\nvue_parc_global]
        [mv_stats_parc\n<i>(materialisee)</i>]
      }
    }

    folder "**Tablespaces Cergy**" as TS_C {
      [TS_MATERIEL_CERGY]
      [TS_NETWORK_CERGY]
      [TS_USERS]
      [TS_INDEX]
      [TS_TEMP]
    }
  }
}

' =============================================================================
' PAU (droite)
' =============================================================================
node "**CY Tech — Pau**\n<size:10><i>Batiment PAU</i></size>" as N_PAU #FDEBD0 {

  database "**Oracle XE 21c**\n<size:10>CDB pau</size>" as DB_P {

    folder "PDB **XE_PAU**" as PDB_P #FFFFFF {

      component "**Schema ADMIN_CYTECH**" as S_P {
        [Materiel Pau\n(ordis, periph, tel,\nlogiciels)]
        [Reseau Pau\n(equipements + ports)]
        [Historique local]
      }

      component "**MV repliquees depuis Cergy**" as MV_P {
        [mv_fabricants\nmv_etats\nmv_sites\nmv_utilisateurs\n<i>REFRESH ON DEMAND</i>]
      }

      component "**Triggers + Packages**\n<size:10>(memes que Cergy)</size>" as PL_P {
        [Audit + validation\n+ packages metier]
      }
    }

    folder "**Tablespaces Pau**" as TS_P {
      [TS_MATERIEL_PAU]
      [TS_NETWORK_PAU]
      [TS_USERS]
      [TS_INDEX]
      [TS_TEMP]
    }
  }
}

' =============================================================================
' ACTEURS (en bas)
' =============================================================================
together {
  actor "**ADMIN_CYTECH**\n<size:9>R_ADMIN</size>" as A_ADMIN
  actor "**TECH_CERGY**\n<size:9>R_TECH_CERGY</size>" as A_TC
  actor "**TECH_PAU**\n<size:9>R_TECH_PAU</size>" as A_TP
  actor "**USER_RO**\n<size:9>R_CONSULTATION</size>" as A_RO
}

' =============================================================================
' LIENS BDDR (au centre)
' =============================================================================
PDB_C <-[#2874A6,thickness=2]-> PDB_P : **DB links bidirectionnels**\n<size:10>db_pau   (Cergy → Pau)\ndb_cergy (Pau → Cergy)</size>

S_C -[#1E8449,dashed,thickness=2]-> MV_P : **Replication**\n<size:10>DBMS_MVIEW.REFRESH</size>

' =============================================================================
' ACCES UTILISATEURS
' =============================================================================
A_ADMIN -[#B9770E]-> PDB_C : DDL + DML
A_ADMIN -[#B9770E]-> PDB_P : DDL + DML
A_TC    -[#229954]-> PDB_C : CRUD parc Cergy
A_TP    -[#C0392B]-> PDB_P : CRUD parc Pau
A_RO    -[#7D3C98,dashed]-> V_C : SELECT sur vues

' =============================================================================
' LIENS DONNEES <-> TABLESPACES (discrets)
' =============================================================================
S_C -[#888,dotted]-> TS_C
S_P -[#888,dotted]-> TS_P

' =============================================================================
' NOTES
' =============================================================================
note bottom of PDB_C
  <b>Site maitre</b> :
  - heberge les referentiels (source unique)
  - audit global
  - script <i>setup_bddr.sql</i> cree les
    DB links et synonymes
end note

note bottom of PDB_P
  <b>Site esclave</b> :
  - materiel et reseau locaux
  - referentiels recus en replication
  - peut fonctionner en mode degrade
    si le lien vers Cergy tombe
end note

legend right
|<#E8F4FD>     | Site Cergy |
|<#FDEBD0>     | Site Pau |
|<#D5F5E3>     | Tablespaces |
|<#FCF3CF>     | Composants logiques |
endlegend

@enduml
