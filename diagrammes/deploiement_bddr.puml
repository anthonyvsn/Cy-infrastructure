@startuml deploiement_bddr
' =============================================================================
' Diagramme de deploiement BDDR -- Projet GLPI CY Tech multi-sites
' Cible : Oracle 21c XE, 2 PDBs sur 2 sites (Cergy, Pau)
' =============================================================================

skinparam shadowing false
skinparam linetype polyline
skinparam node {
  BackgroundColor #FDFEFE
  BorderColor     #34495E
}
skinparam database {
  BackgroundColor #D6EAF8
  BorderColor     #2874A6
}
skinparam component {
  BackgroundColor #FCF3CF
  BorderColor     #B7950B
}
skinparam folder {
  BackgroundColor #D5F5E3
  BorderColor     #1E8449
}

title Architecture BDDR -- GLPI CY Tech (Cergy + Pau)

' =============================================================================
' SITE CERGY
' =============================================================================

node "Site CY Tech Cergy\n(Bat. Condorcet / Cauchy / Turing / Fermat)" as CERGY_SITE #EBF5FB {

  database "CDB Oracle XE 21c" as CDB_CERGY {

    folder "PDB XE_CERGY" as PDB_CERGY {

      component "Schema ADMIN_CYTECH" as SCH_CERGY {
        [Referentiels\n(sites, hierarchy_level,\nlocalisations, profils,\nfabricants, etats...)] as REF_CERGY
        [Utilisateurs + Groupes] as USERS_CERGY
        [Materiel Cergy\n(ordinateurs, peripheriques,\ntelephones, logiciels...)] as MAT_CERGY
        [Reseau Cergy\n(equipements, ports)] as NET_CERGY
        [Cluster\ncl_materiel_localisation\n+ ordinateurs_cl\n+ peripheriques_cl] as CL_CERGY
        [Historique (audit)] as HIST_CERGY
      }

      component "Triggers + Packages PL/SQL" as PLSQL_CERGY {
        [Triggers d'audit\n(log_change)] as TRG_CERGY
        [PKG_PARC_INFO,\nPKG_STATS, PKG_RESEAU,\nPKG_MAINTENANCE\n(PRAGMA AUTONOMOUS)] as PKG_CERGY
      }

      component "Vues" as VUES_CERGY {
        [vue_parc_cergy,\nvue_parc_pau (synonym),\nvue_parc_global (UNION ALL),\nvue_parc_global_v2 (enrichie)] as V_CERGY
        [mv_stats_parc\n(vue materialisee)] as MV_CERGY
      }
    }

    folder "Tablespaces" as TS_CERGY {
      [TS_MATERIEL_CERGY] as TM_C
      [TS_NETWORK_CERGY]  as TN_C
      [TS_USERS]          as TU_C
      [TS_INDEX]          as TI_C
      [TS_TEMP]           as TT_C
    }
  }
}

' =============================================================================
' SITE PAU
' =============================================================================

node "Site CY Tech Pau\n(Bat. PAU)" as PAU_SITE #EBF5FB {

  database "CDB Oracle XE 21c" as CDB_PAU {

    folder "PDB XE_PAU" as PDB_PAU {

      component "Schema ADMIN_CYTECH" as SCH_PAU {
        [Materiel Pau\n(ordinateurs, peripheriques,\ntelephones, logiciels...)] as MAT_PAU
        [Reseau Pau\n(equipements, ports)] as NET_PAU
        [Historique local] as HIST_PAU
      }

      component "Vues materialisees\nrepliquees depuis Cergy" as MV_PAU {
        [mv_fabricants,\nmv_etats, mv_sites,\nmv_utilisateurs\nREFRESH ON DEMAND] as MVS_PAU
      }

      component "Triggers + Packages PL/SQL\n(memes que Cergy)" as PLSQL_PAU {
        [Audit + validation\n+ packages metier] as PKG_PAU
      }
    }

    folder "Tablespaces" as TS_PAU {
      [TS_MATERIEL_PAU]   as TM_P
      [TS_NETWORK_PAU]    as TN_P
      [TS_USERS]          as TU_P
      [TS_INDEX]          as TI_P
      [TS_TEMP]           as TT_P
    }
  }
}

' =============================================================================
' UTILISATEURS / ACTEURS
' =============================================================================

actor "ADMIN_CYTECH\n(R_ADMIN)" as ADMIN
actor "TECH_CERGY\n(R_TECH_CERGY)" as TC
actor "TECH_PAU\n(R_TECH_PAU)" as TP
actor "USER_RO\n(R_CONSULTATION)" as RO

' =============================================================================
' LIENS BDDR
' =============================================================================

' DB Link Cergy -> Pau (interrogation distante)
PDB_CERGY -down-> PDB_PAU : "DB link db_pau\n(CONNECT TO TECH_PAU)"
PDB_PAU   -down-> PDB_CERGY : "DB link db_cergy\n(CONNECT TO TECH_CERGY)"

' Vues globales
V_CERGY ..> MAT_CERGY : local
V_CERGY ..> MAT_PAU   : via db_pau

' Replication des referentiels
REF_CERGY -[#1E8449,dashed]down-> MVS_PAU : "Replication\nREFRESH ON DEMAND\n(DBMS_MVIEW.REFRESH)"

' Acces utilisateurs
ADMIN --> PDB_CERGY : "DDL + DML\nUNLIMITED TABLESPACE"
ADMIN --> PDB_PAU   : "DDL + DML\nUNLIMITED TABLESPACE"
TC    --> PDB_CERGY : "CRUD parc Cergy"
TP    --> PDB_PAU   : "CRUD parc Pau"
RO    --> PDB_CERGY : "SELECT vues uniquement"

' Mapping tablespaces -> donnees
MAT_CERGY -[#888,dotted]-> TM_C
NET_CERGY -[#888,dotted]-> TN_C
REF_CERGY -[#888,dotted]-> TU_C
MAT_PAU   -[#888,dotted]-> TM_P
NET_PAU   -[#888,dotted]-> TN_P

' =============================================================================
' NOTES PEDAGOGIQUES
' =============================================================================

note top of PDB_CERGY
  PDB Cergy = donnees + logique
  + audit global. Sert aussi de
  source pour la replication des
  referentiels vers Pau.
end note

note top of PDB_PAU
  PDB Pau = mat. et reseau locaux.
  Les referentiels sont consommes
  via des vues materialisees
  rafraichies depuis Cergy.
end note

note bottom of V_CERGY
  vue_parc_global utilise db_pau
  via UNION ALL. Un trigger
  INSTEAD OF redirige les INSERT
  vers la bonne instance selon
  site_id (1=Cergy, 2=Pau).
end note

note bottom of MVS_PAU
  Approche pull : Pau interroge
  Cergy pour repliquer fabricants,
  etats, sites, utilisateurs.
  Rafraichissement manuel par
  DBMS_MVIEW.REFRESH ou periodique
  via DBMS_SCHEDULER.
end note

note right of CL_CERGY
  Cluster physique :
  ordinateurs_cl et peripheriques_cl
  partageant une meme localisation_id
  sont stockes ensemble sur disque
  -> gain de perf sur les SELECT
  par localisation.
end note

@enduml
